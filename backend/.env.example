MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=stolen_vehicle_portal
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# N8N Webhook Configuration for Email Notifications
# Get this URL from your n8n cloud instance webhook node
# Example: https://your-instance.n8n.cloud/webhook/stolen-vehicles
# Leave empty to disable notifications
N8N_WEBHOOK_URL=

# Email Notification Settings
# Configure your email provider credentials in n8n
# Supported: Gmail, SendGrid, SMTP
EMAIL_PROVIDER=gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Seed staff accounts (CHANGE PASSWORDS IN PRODUCTION)
ADMIN_SEED_EMAIL=admin@portal.local
ADMIN_SEED_PASSWORD=Admin@123
POLICE_SEED_EMAIL=police@portal.local
POLICE_SEED_PASSWORD=Police@123
